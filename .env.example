DATABASE_URL=postgresql://user:password@localhost:5432/dentsis
NODE_ENV=development
PORT=3000
JWT_ACCESS_SECRET=your-long-random-secret-here
JWT_ACCESS_EXPIRES=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173
ADMIN_BOOTSTRAP_SECRET=your-bootstrap-secret-here

# Static bearer key for the taline → POST /api/slips ingestion endpoint.
# Leave empty to disable auth on that endpoint (taline then omits the Authorization header).
DENSIS_API_KEY=

# Line Messaging API — push notifications to doctors on appointment confirm/cancel.
# Get from: LINE Developers Console → Messaging API channel.
# Leave empty to disable Line notifications and webhook verification.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# Hours before a doctor invite code expires (default: 24)
LINE_INVITE_EXPIRY_HOURS=24

# Feature toggles (set to "true" to enable)
FEATURE_SLIP_RECEIVER=false
FEATURE_APPOINTMENTS=false
